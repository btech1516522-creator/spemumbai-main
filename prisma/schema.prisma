// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  date      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadershipMember {
  id           String   @id @default(cuid())
  name         String
  position     String
  organization String
  bio          String
  linkedin     String?
  image        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id                  String              @id @default(cuid())
  title               String
  date                String
  endDate             String?
  location            String
  description         String
  image               String?
  active              Boolean             @default(true)
  registrationEnabled Boolean             @default(false)
  proposalPurpose     String?
  proposalLink        String?
  sortOrder           Int                 @default(0)
  registrations       EventRegistration[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  company   String?
  message   String?
  createdAt DateTime @default(now())

  @@index([eventId])
}

model Report {
  id          String   @id @default(cuid())
  title       String
  coverImage  String?
  pdfUrl      String
  description String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  tableName  String
  recordId   String?
  action     String
  oldData    String?
  newData    String?
  changedBy  String
  changedAt  DateTime @default(now())
}

model GalleryEvent {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  date       String
  coverImage String
  images     String   // JSON array of image paths
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StudentChapter {
  id           String   @id @default(cuid())
  name         String
  university   String
  location     String
  established  String
  description  String
  website      String?
  image        String?
  achievements String   // JSON array
  activities   String   // JSON array
  leadership   String   // JSON array of {position, name}
  sortOrder    Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VolunteerRole {
  id              String   @id @default(cuid())
  title           String
  category        String   // education, events, outreach, etc.
  description     String
  responsibilities String
  timeCommitment  String
  location        String
  teamWork        String
  skills          String
  benefits        String
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
